# vim: set ft=sxhkdrc:

# make sxhkd reload its configuration files:
super + shift + control + x
    pkill -usr1 -x sxhkd; notify-send -t 500 'sxhkd' 'Reloaded config'

# Dmenu Scripts
alt + super + {v,r,n,e,u,slash,u}
    dmenu-{greenclip,remmina,networkmanager,edit-configs,pacman,scrot,pacman}

super + p
    rofi -show run

alt + super + b
    dmqute

alt + super + i
    rofi-vbox

alt + super + {s,m,}
    dmenu-{audio-select,mpd}

alt + super + c
    dmenu-calculator

alt + super + {l,p}
    {dmenu-lastpass copy,bwmenu}

super + shift + p
    rofi -show drun

super + Tab
    rofi -show window

super + shift + e
    kitty --class quickedit -e nvim

# Lockscreen
super + Escape
    mpc pause; xfce4-screensaver-command -l

super + shift + m
    music-manager

# App Launcers
super + {F2,F3,F4,F6,F7,F8}
    {google-chrome-stable,qutebrowser,emacs,filemanager,dbeaver,virtualbox}

super + alt + d
    lazygit-dots

### MEDIA KEYS ###
# MPD Controls
XF86AudioPlay
	mpc toggle

XF86Audio{Next,Prev}
    mpc {next,prev}

XF86AudioMute
    pamixer --mute; notify-send -t 500 'Volume' 'Volume Muted'

XF86AudioRaiseVolume
    pamixer -u -i 5; notify-send -t 500  'Volume Set' -h string:x-canonical-private-synchronous:anything "$(pamixer --get-volume)%"

XF86AudioLowerVolume
    pamixer -u -d 5; notify-send -t 500  'Volume Set' -h string:x-canonical-private-synchronous:anything "$(pamixer --get-volume)%"
