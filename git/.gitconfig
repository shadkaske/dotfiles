[user]
name = Shad Kaske
email = shadkaske@gmail.com
[core]
editor = nvim
[merge]
tool = nvim
[diff]
tool = nvimdiff
[mergetool]
keepBackup = false
prompt = false
[difftool "nvimdiff"]
cmd = nvim -f -c "Gdiffsplit!" "$MERGED"
[mergetool "nvim"]
cmd = nvim -f -c "Gdiffsplit!" "$MERGED"
layout = "LOCAL,BASE,REMOTE / MERGED"
[difftool "nvimdiff"]
cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""
[mergetool "vimdiff"]
vimdiff
[pull]
rebase = true
[init]
defaultBranch = main
[protocol "file"]
allow = always
[push]
autoSetupRemote = true
