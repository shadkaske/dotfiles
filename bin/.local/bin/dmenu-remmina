#!/bin/bash

command='remmina'
location="$HOME/.local/share/remmina"
names=$(ag --no-group '^name' $location | cut -d "=" -f2)
windo=$(echo $'\nMain Window\nPreferences\nNew Connection')

selected=$(echo "$names $windo" | dmenu -i -l 8 -p "Remmina Connections")

if [[ ! -z $selected ]]; then
    case $selected in
        "Main Window")
            $command
            ;;

        "Preferences")
            $command -p 0
            ;;

        "New Connection")
            $command --new
            ;;

        *)
            remminafile=$(ag -l $selected $location)
            $command --connect="$remminafile"
            ;;
    esac
fi
