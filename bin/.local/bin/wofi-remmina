#!/usr/bin/env bash
command="$(which remmina)"
remmina_location="$HOME/.local/share/remmina"
dmenu_command="wofi -d -i -p 'Remmina Connections'"

declare -A connections

connections["Main Window"]="$command"
connections["Preferences"]="$command -p 0"
connections["New Connection"]="$command --new"

FILES="$remmina_location/*.remmina"
for f in $FILES; do
  if [ -f "$f" ]; then
    con_name=$(grep '^name' "$f" | cut -d "=" -f2)
    if [[ -n "$con_name" ]]; then
      connections[$con_name]="$command -c $f"
    fi
  fi
done

for key in "${!connections[@]}"; do
  keys+="$key
  "
done

selected=$(echo "$keys" | $dmenu_command)

[ -z "$selected" ] && exit 0

select_key=$(echo $selected | xargs echo -n)

command=$(echo "${connections[$select_key]}")
eval $command
