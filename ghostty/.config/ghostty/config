window-padding-x = 4
window-padding-y = 6

font-family = "JetBrainsMono NFM Thin"
font-family-bold = "JetBrainsMono NFM SemiBold"
font-family-italic = "JetBrainsMono NFM Thin Italic"
font-family-bold-italic = "JetBrainsMono NFM SemiBold Italic"
font-size = 13

confirm-close-surface = false

theme = "tokyonight"

term=xterm-256color

command = /bin/zsh
shell-integration=detect

keybind = ctrl+shift+l=clear_screen
keybind = ctrl+shift+d=toggle_window_decorations
