{
  "layer": "top",
  "position": "top",
  "spacing": 0,
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [
    "hyprland/window",
    "custom/separator",
    "mpris"
  ],
  "modules-right": [
    "network",
    "pulseaudio",
    "bluetooth",
    "battery",
    "backlight",
    "tray",
    "clock",
    "custom/notification",
    "custom/power"
  ],
  "hyprland/window": {
    "(.*) - Mozilla Firefox": "Firefox"
  },
  "hyprland/workspaces": {
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "active": "ΎΗΤ",
      "default": "ΎΗΤ",
      "empty": "ΎΘδ",
      "urgent": "ΎΕΣ"
    },
    "persistent-workspaces": {
      "*": [
        1,
        2,
        3,
        4,
        5,
        6,
        7,
        8,
        9
      ]
    }
  },
  "mpris": {
    "format": "{player_icon} {status_icon} {title} - {artist}",
    "format-paused": "{player_icon} {status_icon} {title} - {artist}",
    "player-icons": {
      "default": "Ό░δ ",
      "chromium": "ΎΚρ ",
      "firefox": "ΎΚσ "
    },
    "status-icons": {
      "paused": "ΎΒΝ ",
      "playing": "ΎΒΜ "
    },
    "dynamic-length": 30
  },
  "memory": {
    "interval": 5,
    "format": "≤░Ξδ {}%",
    "max-length": 10
  },
  "tray": {
    "spacing": 10,
    "icon-size": 14
  },
  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "format-alt": "{:%a, %d %b %Y}",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#89b4fa'><b>{}</b></span>",
        "days": "<span color='#cdd6f4'>{}</span>",
        "weeks": "<span color='#f9e2af'><b>W{}</b></span>",
        "weekdays": "<span color='#f9e2af'><b>{}</b></span>",
        "today": "<span color='#cba6f7'><b>{}</b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "network": {
    "format-ethernet": "≤░δ│",
    "format-alt": "≤░Ψσ",
    "format-wifi": "{icon}",
    "format-disconnected": "≤░Ψς",
    "tooltip-format-wifi": "{icon} {essid}\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}\n{signalStrength}",
    "tooltip-format-ethernet": "≤░ΑΓ  {ifname}\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "nm-connection-editor",
    "interval": 5,
    "nospacing": 1,
    "format-icons": [
      "≤░νψ",
      "≤░νθ",
      "≤░νλ",
      "≤░νξ",
      "≤░νρ"
    ]
  },
  "backlight": {
    "device": "amdgpu_bl1",
    "interval": 2,
    "align": 0,
    "rotate": 0,
    "format": "{icon}",
    "format-icons": [
      "≤░Δη",
      "≤░Δθ",
      "≤░Δι"
    ]
  },
  "network#wifi": {
    "interface": "wlan0",
    "format-wifi": "{icon}",
    "format-icons": [
      "≤░νθ",
      "≤░νλ",
      "≤░νξ",
      "≤░νρ",
      "≤░νψ"
    ],
    "format-disconnected": "",
    "tooltip-format-wifi": "{icon} {essid}\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
    "on-click": "nm-connection-editor",
    "interval": 5,
    "nospacing": 1
  },
  "pulseaudio": {
    "format": "{icon}",
    "format-bluetooth": "≤░Γ░",
    "nospacing": 1,
    "tooltip-format": "Volume : {volume}%",
    "format-muted": "≤░ζθ",
    "format-icons": {
      "headphone": "ΎΑξ",
      "default": [
        "≤░Χ┐",
        "≤░ΨΑ",
        "≤░Χ╛",
        "≤░ζθ"
      ]
    },
    "on-click": "kitty --app-id=wiremix --title='Mixer' -e wiremix",
    "scroll-step": 1
  },
  "battery": {
    "format": "{icon}",
    "format-full": "≤▒Ρξ",
    "format-plugged": "≤▒Ρξ",
    "format-icons": {
      "charging": [
        "≤░λε",
        "≤░ΓΗ",
        "≤░ΓΘ",
        "≤░ΓΙ",
        "≤░λζ",
        "≤░ΓΚ",
        "≤░λη",
        "≤░ΓΛ",
        "≤░ΓΜ",
        "≤░ΓΖ"
      ],
      "default": [
        "≤░Β║",
        "≤░Β╗",
        "≤░Β╝",
        "≤░Β╜",
        "≤░Β╛",
        "≤░Β┐",
        "≤░ΓΑ",
        "≤░ΓΒ",
        "≤░ΓΓ",
        "≤░Β╣"
      ]
    },
    "interval": 5,
    "states": {
      "warning": 20,
      "critical": 10
    },
    "tooltip": false
  },
  "bluetooth": {
    "format": "≤░Γψ",
    "format-disabled": "≤░Γ▓", // an empty format will hide the module
    "format-connected": "≤░Γ▒",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "kitty --app-id=bluetui --title=Bluetooth -e bluetui-gnu"
  },
  "custom/separator": {
    "format": "|",
    "interval": "once",
    "tooltip": false
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "ΎΔ│",
      "none": "ΎΓλ",
      "dnd-notification": "ΎΘ╢ ",
      "dnd-none": "  ",
      "inhibited-notification": "ΎΓλ ",
      "inhibited-none": "ΎΓλ",
      "dnd-inhibited-notification": "ΎΘ╖ ",
      "dnd-inhibited-none": "ΎΘ╖ "
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "on-click-right": "sleep 0.1 && swaync-client -d -sw",
    "escape": true
  },
  "custom/power": {
    "tooltip": false,
    "on-click": "wlogout &",
    "format": "ΎΑΣ"
  }
}
// vim: ft=jsonc
