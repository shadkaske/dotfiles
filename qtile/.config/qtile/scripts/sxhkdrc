# Reload sxhkdrc
super + shift + control + x
    pkill -usr1 -x sxhkd; notify-send 'sxhkd' 'Reloaded config'

super + p
    rofi -show run

super + Escape
    mpc pause; xfce4-screensaver-command -l

super + alt + {v, n}
    {dmenu-greenclip, dmenu-networkmanager}

super + Tab
    rofi -show window
