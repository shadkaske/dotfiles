configuration {
    modi: "window,drun,run,ssh,combi";
    location: 2;
    /* yoffset: 24; */
    font: "JetBrainsMono Nerd Font 12";
    terminal: "kitty";
    matching: "fuzzy";
    fake-transparency: true;
    display-ssh:    "  " ;
    display-run:    "  " ;
    display-drun:   "  " ;
    display-window: "  " ;
    display-combi:  "  " ;
    show-icons:     true;
}

@theme "Arc-Dark"

